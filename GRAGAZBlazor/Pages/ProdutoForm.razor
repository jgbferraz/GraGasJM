@page "/produto/novo"
@page "/produto/editar/{Id:int}"
@using GraGasJM.Models
@using GraGasJM.Application.Abstractions
@using GraGasJM.Application.Produtos
@inject IProdutoRepository ProdutoRepository
@inject ISalvarProdutoUseCase SalvarProdutoUseCase
@inject NavigationManager Navigation

<PageTitle>@(Id == null ? "Novo Produto" : "Editar Produto")</PageTitle>

<h1>@(Id == null ? "Novo Produto" : "Editar Produto")</h1>

<div class="row">
    <div class="col-md-6">
        <EditForm Model="@produto" OnValidSubmit="@SalvarProduto">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label for="nome" class="form-label">Nome</label>
                <InputText id="nome" class="form-control" @bind-Value="produto.Nome" />
                <ValidationMessage For="@(() => produto.Nome)" />
            </div>

            <div class="mb-3">
                <label for="categoria" class="form-label">Categoria</label>
                <InputSelect id="categoria" class="form-control" @bind-Value="produto.Categoria">
                    @foreach (var categoria in Enum.GetValues<CategoriaProduto>())
                    {
                        <option value="@categoria">@categoria.ToString()</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => produto.Categoria)" />
            </div>

            <div class="mb-3">
                <label for="descricao" class="form-label">Descrição</label>
                <InputTextArea id="descricao" class="form-control" @bind-Value="produto.Descricao" rows="3" />
                <ValidationMessage For="@(() => produto.Descricao)" />
            </div>

            <div class="mb-3">
                <label for="precoVenda" class="form-label">Preço de Venda</label>
                <InputNumber id="precoVenda" class="form-control" @bind-Value="produto.PrecoVenda" />
                <ValidationMessage For="@(() => produto.PrecoVenda)" />
            </div>

            <div class="mb-3">
                <label for="precoCompra" class="form-label">Preço de Compra</label>
                <InputNumber id="precoCompra" class="form-control" @bind-Value="produto.PrecoCompra" />
                <ValidationMessage For="@(() => produto.PrecoCompra)" />
            </div>

            <div class="mb-3">
                <label for="quantidadeEstoque" class="form-label">Quantidade em Estoque</label>
                <InputNumber id="quantidadeEstoque" class="form-control" @bind-Value="produto.QuantidadeEstoque" />
                <ValidationMessage For="@(() => produto.QuantidadeEstoque)" />
            </div>

            <div class="mb-3">
                <label for="estoqueMinimo" class="form-label">Estoque Mínimo</label>
                <InputNumber id="estoqueMinimo" class="form-control" @bind-Value="produto.EstoqueMinimo" />
                <ValidationMessage For="@(() => produto.EstoqueMinimo)" />
            </div>

            <div class="mb-3 form-check">
                <InputCheckbox id="ativo" class="form-check-input" @bind-Value="produto.Ativo" />
                <label class="form-check-label" for="ativo">Ativo</label>
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Salvar</button>
                <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public int? Id { get; set; }

    private Produto produto = new();

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var produtoExistente = await ProdutoRepository.ObterPorIdAsync(Id.Value);
            if (produtoExistente != null)
            {
                produto = produtoExistente;
            }
        }
    }

    private async Task SalvarProduto()
    {
        var resultado = await SalvarProdutoUseCase.ExecutarAsync(new SalvarProdutoCommand
        {
            Id = Id,
            Nome = produto.Nome,
            Categoria = produto.Categoria,
            Descricao = produto.Descricao,
            PrecoVenda = produto.PrecoVenda,
            PrecoCompra = produto.PrecoCompra,
            QuantidadeEstoque = produto.QuantidadeEstoque,
            EstoqueMinimo = produto.EstoqueMinimo,
            Ativo = produto.Ativo
        });

        if (!resultado.IsSuccess)
        {
            return;
        }

        Navigation.NavigateTo("/produtos");
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/produtos");
    }
}
