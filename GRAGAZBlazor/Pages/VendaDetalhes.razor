@page "/venda/detalhes/{Id:int}"
@using GraGasJM.Application.Abstractions
@using GraGasJM.Models
@inject IVendaRepository VendaRepository
@inject NavigationManager Navigation

<PageTitle>Detalhes da Venda</PageTitle>

<h1>Detalhes da Venda</h1>

@if (venda == null)
{
    <p><em>Carregando...</em></p>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <p><strong>Data:</strong> @venda.DataVenda.ToString("dd/MM/yyyy HH:mm")</p>
            <p><strong>Cliente:</strong> @(string.IsNullOrEmpty(venda.NomeCliente) ? "Cliente não informado" : venda.NomeCliente)</p>
            <p><strong>Forma de pagamento:</strong> @venda.FormaPagamento</p>
            <p><strong>Total:</strong> @venda.ValorTotal.ToString("C")</p>
            <p><strong>Observações:</strong> @(string.IsNullOrEmpty(venda.Observacoes) ? "-" : venda.Observacoes)</p>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h5>Itens</h5>
        </div>
        <div class="card-body">
            <table class="table">
                <thead>
                    <tr>
                        <th>Produto</th>
                        <th>Quantidade</th>
                        <th>Preço Unit.</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in venda.Itens)
                    {
                        <tr>
                            <td>@(item.Produto?.Nome ?? "Produto não informado")</td>
                            <td>@item.Quantidade</td>
                            <td>@item.PrecoUnitario.ToString("C")</td>
                            <td>@item.Subtotal.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3">
        <button class="btn btn-secondary" @onclick="Voltar">Voltar</button>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Venda? venda;

    protected override async Task OnInitializedAsync()
    {
        venda = await VendaRepository.ObterPorIdComItensAsync(Id);
    }

    private void Voltar()
    {
        Navigation.NavigateTo("/vendas");
    }
}