@page "/vendas"
@using GraGasJM.Models
@using GraGasJM.Application.Abstractions
@using GraGasJM.Application.Vendas
@inject IVendaRepository VendaRepository
@inject IRemoverVendaUseCase RemoverVendaUseCase
@inject NavigationManager Navigation

<PageTitle>Vendas</PageTitle>

<h1>Gerenciamento de Vendas</h1>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="NovaVenda">
        <span class="oi oi-plus"></span> Nova Venda
    </button>
</div>

@if (vendas == null)
{
    <p><em>Carregando...</em></p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Data</th>
                <th>Cliente</th>
                <th>Valor Total</th>
                <th>Forma de Pagamento</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var venda in vendas)
            {
                <tr>
                    <td>@venda.DataVenda.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@(string.IsNullOrEmpty(venda.NomeCliente) ? "Cliente não informado" : venda.NomeCliente)</td>
                    <td>@venda.ValorTotal.ToString("C")</td>
                    <td>@venda.FormaPagamento</td>
                    <td>
                        <button class="btn btn-sm btn-info" @onclick="() => VisualizarVenda(venda.Id)">
                            <span class="oi oi-eye"></span>
                        </button>
                        <button class="btn btn-sm btn-danger" @onclick="() => ExcluirVenda(venda.Id)">
                            <span class="oi oi-trash"></span>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (vendas.Count == 0)
    {
        <div class="alert alert-info">Nenhuma venda registrada.</div>
    }
}

@code {
    private List<Venda>? vendas;

    protected override async Task OnInitializedAsync()
    {
        await CarregarVendas();
    }

    private async Task CarregarVendas()
    {
        vendas = await VendaRepository.ObterTodasAsync();
    }

    private void NovaVenda()
    {
        Navigation.NavigateTo("/venda/nova");
    }

    private void VisualizarVenda(int id)
    {
        Navigation.NavigateTo($"/venda/detalhes/{id}");
    }

    private async Task ExcluirVenda(int id)
    {
        var resultado = await RemoverVendaUseCase.ExecutarAsync(id);
        if (!resultado.IsSuccess)
        {
            return;
        }

        await CarregarVendas();
    }
}
