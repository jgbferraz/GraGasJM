@page "/venda/nova"
@using GraGasJM.Models
@using GraGasJM.Application.Abstractions
@using GraGasJM.Application.Vendas
@inject IProdutoRepository ProdutoRepository
@inject ICriarVendaUseCase CriarVendaUseCase
@inject NavigationManager Navigation

<PageTitle>Nova Venda</PageTitle>

<h1>Nova Venda</h1>

<div class="row">
    <div class="col-md-8">
        <EditForm Model="@venda" OnValidSubmit="@SalvarVenda">
            <DataAnnotationsValidator />

            <div class="card mb-3">
                <div class="card-header">
                    <h5>Informações da Venda</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="dataVenda" class="form-label">Data</label>
                            <InputDate id="dataVenda" class="form-control" @bind-Value="venda.DataVenda" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="formaPagamento" class="form-label">Forma de Pagamento</label>
                            <InputSelect id="formaPagamento" class="form-control" @bind-Value="venda.FormaPagamento">
                                <option value="@FormaPagamento.DinheiroPix">Dinheiro / PIX</option>
                                <option value="@FormaPagamento.CartaoDebito">Cartão de Débito</option>
                                <option value="@FormaPagamento.CartaoCredito">Cartão de Crédito</option>
                            </InputSelect>
                            @if (venda.FormaPagamento == FormaPagamento.DinheiroPix)
                            {
                                <small class="text-success">Desconto de R$ 3,00 por botíjão P13</small>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="nomeCliente" class="form-label">Nome do Cliente (opcional)</label>
                        <InputText id="nomeCliente" class="form-control" @bind-Value="venda.NomeCliente" />
                    </div>

                    <div class="mb-3">
                        <label for="observacoes" class="form-label">Observações</label>
                        <InputTextArea id="observacoes" class="form-control" @bind-Value="venda.Observacoes" rows="2" />
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">
                    <h5>Itens da Venda</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="produtoSelecionado" class="form-label">Produto</label>
                            <select id="produtoSelecionado" class="form-control" @bind="produtoSelecionadoId">
                                <option value="0">Selecione um produto...</option>
                                @foreach (var prod in produtos)
                                {
                                    <option value="@prod.Id">@prod.Nome - Estoque: @prod.QuantidadeEstoque</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="quantidade" class="form-label">Quantidade</label>
                            <input type="number" id="quantidade" class="form-control" @bind="quantidadeItem" min="1" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">&nbsp;</label>
                            <button type="button" class="btn btn-success w-100" @onclick="AdicionarItem">
                                <span class="oi oi-plus"></span> Adicionar
                            </button>
                        </div>
                    </div>

                    @if (mensagemErro != null)
                    {
                        <div class="alert alert-danger">@mensagemErro</div>
                    }

                    <table class="table">
                        <thead>
                            <tr>
                                <th>Produto</th>
                                <th>Quantidade</th>
                                <th>Preço Unit.</th>
                                <th>Subtotal</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in itens)
                            {
                                <tr>
                                    <td>@item.Produto?.Nome</td>
                                    <td>@item.Quantidade</td>
                                    <td>@ObterPrecoUnitarioExibicao(item).ToString("C")</td>
                                    <td>@ObterSubtotal(item).ToString("C")</td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-danger"
                                                @onclick="() => RemoverItem(item)">
                                            <span class="oi oi-trash"></span>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="3" class="text-end">Total:</th>
                                <th>@CalcularTotal().ToString("C")</th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-primary" disabled="@(itens.Count == 0)">Finalizar Venda</button>
                <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private Venda venda = new();
    private List<ItemVenda> itens = new();
    private List<Produto> produtos = new();
    private int produtoSelecionadoId = 0;
    private int quantidadeItem = 1;
    private string? mensagemErro;


    protected override async Task OnInitializedAsync()
    {
        produtos = await ProdutoRepository.ObterAtivosAsync();
    }

    private void AdicionarItem()
    {
        mensagemErro = null;

        if (produtoSelecionadoId == 0)
        {
            mensagemErro = "Selecione um produto";
            return;
        }

        if (quantidadeItem <= 0)
        {
            mensagemErro = "A quantidade deve ser maior que zero";
            return;
        }

        var produto = produtos.FirstOrDefault(p => p.Id == produtoSelecionadoId);
        if (produto == null)
        {
            mensagemErro = "Produto não encontrado";
            return;
        }

        if (produto.QuantidadeEstoque < quantidadeItem)
        {
            mensagemErro = $"Estoque insuficiente. Disponível: {produto.QuantidadeEstoque}";
            return;
        }

        var itemExistente = itens.FirstOrDefault(i => i.ProdutoId == produtoSelecionadoId);
        if (itemExistente != null)
        {
            itemExistente.Quantidade += quantidadeItem;
        }
        else
        {
            itens.Add(new ItemVenda
            {
                ProdutoId = produto.Id,
                Produto = produto,
                Quantidade = quantidadeItem,
                PrecoUnitario = produto.PrecoVenda
            });
        }

        produtoSelecionadoId = 0;
        quantidadeItem = 1;
    }

    private void RemoverItem(ItemVenda item)
    {
        itens.Remove(item);
    }

    private decimal ObterPrecoUnitarioExibicao(ItemVenda item) =>
        VendaPricingPolicy.CalcularPrecoUnitario(
            item.PrecoUnitario,
            venda.FormaPagamento,
            item.Produto?.Nome);

    private decimal ObterSubtotal(ItemVenda item) =>
        VendaPricingPolicy.CalcularSubtotal(
            item.PrecoUnitario,
            item.Quantidade,
            venda.FormaPagamento,
            item.Produto?.Nome);

    private decimal CalcularTotal() =>
        itens.Sum(i => ObterSubtotal(i));


    private async Task SalvarVenda()
    {
        if (itens.Count == 0)
        {
            mensagemErro = "Adicione pelo menos um item à venda";
            return;
        }

        var command = new CriarVendaCommand
        {
            DataVenda = venda.DataVenda,
            NomeCliente = venda.NomeCliente,
            Observacoes = venda.Observacoes,
            FormaPagamento = venda.FormaPagamento,
            Itens = itens.Select(i => new CriarVendaItemCommand
            {
                ProdutoId = i.ProdutoId,
                Quantidade = i.Quantidade
            }).ToList()
        };

        var resultado = await CriarVendaUseCase.ExecutarAsync(command);
        if (!resultado.IsSuccess)
        {
            mensagemErro = resultado.Error;
            return;
        }

        Navigation.NavigateTo("/vendas");
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/vendas");
    }
}
